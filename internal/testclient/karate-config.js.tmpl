function fn() {
  // generated by gherkin-tester — do not edit
  var config = {
{{- range $k, $v := .Properties}}
    '{{$k}}': '{{escapeJS $v}}',
{{- end}}
  }
{{- if .HTTPProxy}}
  config.httpProxy = '{{escapeJS .HTTPProxy}}'
  karate.configure('proxy', '{{escapeJS .HTTPProxy}}')
{{- end}}
{{- if .MTLS}}
  config['ssl.cert'] = '{{escapeJS .MTLS.CertificatePath}}'
  config['ssl.key'] = '{{escapeJS .MTLS.PrivateKeyPath}}'
{{- if .MTLS.PrivateKeyPassword}}
  config['ssl.keyPassword'] = '{{escapeJS .MTLS.PrivateKeyPassword}}'
{{- else if .MTLS.PasswordRedacted}}
  // ssl.keyPassword configured via environment (redacted)
{{- end}}
{{- end}}
  return config
}
